# Copy this file to .env to override llama-codex defaults locally.

LLAMA_CODEX_MODEL="qwen3-coder-30b-65k"
LLAMA_CODEX_CONTEXT_WINDOW=65536

LLAMA_CODEX_OLLAMA_URL="http://127.0.0.1:11434"
LLAMA_CODEX_PROXY_HOST="127.0.0.1"
LLAMA_CODEX_PROXY_PORT=11435

LLAMA_CODEX_OLLAMA_NUM_PARALLEL=1
LLAMA_CODEX_OLLAMA_MAX_LOADED_MODELS=1

LLAMA_CODEX_LOG_DIR="${HOME}/.ollama"
LLAMA_CODEX_CACHE_DIR="${HOME}/.cache/llama-codex"

# Keep the visible tool surface narrow enough for local models.
# Lean mode preserves exec_command and hides write_stdin to avoid bogus session-id calls.
LLAMA_CODEX_TOOL_PROFILE=lean

# Optional: override the default local-agent steering instructions.
# LLAMA_CODEX_BASE_INSTRUCTIONS="Read relevant files first, edit directly, run tests, keep action output compact, execute PRDs in verified slices, and report the exact verification command."
