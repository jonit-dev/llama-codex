# Copy this file to .env to override llama-codex defaults locally.

LLAMA_CODEX_MODEL="hf.co/deepreinforce-ai/Ornith-1.0-9B-GGUF:Q4_K_M"
LLAMA_CODEX_CONTEXT_WINDOW=65536

LLAMA_CODEX_OLLAMA_URL="http://127.0.0.1:11434"
LLAMA_CODEX_PROXY_HOST="127.0.0.1"
LLAMA_CODEX_PROXY_PORT=11435

LLAMA_CODEX_OLLAMA_NUM_PARALLEL=1
LLAMA_CODEX_OLLAMA_MAX_LOADED_MODELS=1

LLAMA_CODEX_LOG_DIR="${HOME}/.ollama"
LLAMA_CODEX_CACHE_DIR="${HOME}/.cache/llama-codex"

# Keep the visible tool surface narrow for smaller local models.
LLAMA_CODEX_DENY_TOOL_PATTERN="^(list_mcp_resources|list_mcp_resource_templates|read_mcp_resource|tool_search_tool|write_stdin|request_user_input|list_available_plugins_to_install|request_plugin_install|update_plan|view_image)$"
