#!/usr/bin/env bash
set -euo pipefail

script_path="${BASH_SOURCE[0]}"
while [[ -L "${script_path}" ]]; do
  script_dir="$(cd "$(dirname "${script_path}")" && pwd)"
  link_target="$(readlink "${script_path}")"
  if [[ "${link_target}" == /* ]]; then
    script_path="${link_target}"
  else
    script_path="${script_dir}/${link_target}"
  fi
done
project_root="$(cd "$(dirname "${script_path}")/.." && pwd)"
proxy_script="${project_root}/src/ollama_codex_proxy.py"
env_file="${LLAMA_CODEX_ENV_FILE:-${project_root}/.env}"

if [[ -f "${env_file}" ]]; then
  set -a
  # shellcheck source=/dev/null
  source "${env_file}"
  set +a
fi

qwen3_65k_alias="qwen3-coder-30b-65k"
qwen3_65k_base_model="hf.co/unsloth/Qwen3-Coder-30B-A3B-Instruct-GGUF:UD-Q4_K_XL"
default_model="${qwen3_65k_alias}"
model="${LLAMA_CODEX_MODEL:-${default_model}}"
context_window="${LLAMA_CODEX_CONTEXT_WINDOW:-65536}"
max_output_tokens="${LLAMA_CODEX_MAX_OUTPUT_TOKENS:-2048}"
ollama_url="${LLAMA_CODEX_OLLAMA_URL:-http://127.0.0.1:11434}"
proxy_host="${LLAMA_CODEX_PROXY_HOST:-127.0.0.1}"
proxy_port="${LLAMA_CODEX_PROXY_PORT:-11435}"
proxy_url="http://${proxy_host}:${proxy_port}"
log_dir="${LLAMA_CODEX_LOG_DIR:-${HOME}/.ollama}"
cache_dir="${LLAMA_CODEX_CACHE_DIR:-${HOME}/.cache/llama-codex}"
pid_file="${cache_dir}/proxy-${proxy_port}.pid"
model_catalog="${cache_dir}/model-${proxy_port}.json"
ollama_num_parallel="${LLAMA_CODEX_OLLAMA_NUM_PARALLEL:-${OLLAMA_NUM_PARALLEL:-1}}"
ollama_max_loaded_models="${LLAMA_CODEX_OLLAMA_MAX_LOADED_MODELS:-${OLLAMA_MAX_LOADED_MODELS:-1}}"
default_base_instructions="$(cat <<'EOF'
You are running inside Codex as a local coding agent.

Operate mechanically:
- Read the task and relevant files before editing.
- Prefer targeted edits over rewriting large files.
- Do not create placeholder files with touch.
- Use exec_command to run apply_patch for manual file creation and edits; do not call an apply_patch tool directly.
- Valid patch syntax is: apply_patch <<'PATCH', then a patch beginning with *** Begin Patch, then PATCH on its own line. Do not use apply_patch --file or --patch flags.
- In *** Update File hunks, every unchanged context line must start with one leading space, removed lines with -, and added lines with +.
- If you are not certain an Update hunk is valid, replace the file with *** Delete File followed by *** Add File containing the full corrected file.
- Do not write source files with cat heredocs, echo redirects, tee, shell redirects, or Python file writes unless a generator requires it.
- Do not rely on truncated command output for final conclusions.
- Run the smallest relevant test first, then broader tests when needed.
- If a test fails, inspect the failure and make the minimal repair.
- Keep planning brief; edit files and verify.
- Avoid MCP, plugin, image, browser, cloud, and external tools unless explicitly required.
- Stop when tests pass and report the exact verification command.

Keep action output compact:
- Avoid filler, apologies, and long narration.
- Do not announce obvious tool use.
- Do not restate the task after reading it.
- Prefer one concise status sentence before acting.
- Quote only the shortest decisive error line unless full logs are needed.
- When work is done, report changes, verification commands, and remaining risks only.

For PRDs and implementation plans:
- Treat acceptance criteria and verification steps as requirements.
- Do not stop after restating the PRD or saying you will inspect files.
- Inspect the relevant files, then begin the first concrete implementation or test slice.
- Work phase by phase; finish and verify one coherent slice before starting the next.
- Prefer existing project patterns over new architecture.
- Do not mark PRD work complete without running the PRD's verification steps.
- If the PRD is ambiguous, inspect the codebase and make the smallest reasonable assumption; stop only for truly blocking ambiguity.
- Keep final output limited to completed changes, verification commands, and remaining risks.
EOF
)"
if [[ -v LLAMA_CODEX_BASE_INSTRUCTIONS ]]; then
  base_instructions="${LLAMA_CODEX_BASE_INSTRUCTIONS}"
  base_instructions_source="env"
else
  base_instructions="${default_base_instructions}"
  base_instructions_source="default"
fi
standard_deny_tool_pattern='^(list_mcp_resources|list_mcp_resource_templates|read_mcp_resource|tool_search_tool|list_available_plugins_to_install|request_plugin_install|request_user_input|update_plan|view_image|get_goal|create_goal|update_goal|parallel)$'
lean_deny_tool_pattern='^(write_stdin|list_mcp_resources|list_mcp_resource_templates|read_mcp_resource|tool_search_tool|list_available_plugins_to_install|request_plugin_install|request_user_input|update_plan|view_image|get_goal|create_goal|update_goal|parallel)$'
tiny_deny_tool_pattern='^(?!(?:.*\.)?exec_command$).+'
tool_profile="${LLAMA_CODEX_TOOL_PROFILE:-lean}"
deny_tool_pattern="${LLAMA_CODEX_DENY_TOOL_PATTERN:-}"
reject_shell_writes="${LLAMA_CODEX_REJECT_SHELL_WRITES:-1}"
verify_command="${LLAMA_CODEX_VERIFY_COMMAND:-}"
verify_retries="${LLAMA_CODEX_VERIFY_RETRIES:-0}"
retry_context_bytes="${LLAMA_CODEX_RETRY_CONTEXT_BYTES:-45000}"
restart_proxy=false
stop_proxy=false
action="run"
assume_yes=false

apply_tool_profile() {
  case "${tool_profile}" in
    lean)
      deny_tool_pattern="${lean_deny_tool_pattern}"
      ;;
    standard)
      deny_tool_pattern="${standard_deny_tool_pattern}"
      ;;
    full)
      deny_tool_pattern=""
      ;;
    tiny)
      deny_tool_pattern="${tiny_deny_tool_pattern}"
      ;;
    *)
      echo "llama-codex: unknown tool profile: ${tool_profile}" >&2
      echo "llama-codex: expected one of: lean, standard, full, tiny" >&2
      exit 2
      ;;
  esac
}

if [[ -z "${deny_tool_pattern}" ]]; then
  apply_tool_profile
else
  tool_profile="custom"
fi

args=()
while (($#)); do
  case "$1" in
    init|doctor)
      action="$1"
      shift
      ;;
    -m|--model)
      if (($# < 2)); then
        echo "llama-codex: $1 requires a model value" >&2
        exit 2
      fi
      model="$2"
      args+=("$1" "$2")
      shift 2
      ;;
    --model=*)
      model="${1#--model=}"
      args+=("$1")
      shift
      ;;
    --llama-model)
      if (($# < 2)); then
        echo "llama-codex: $1 requires a model value" >&2
        exit 2
      fi
      model="$2"
      shift 2
      ;;
    --llama-model=*)
      model="${1#--llama-model=}"
      shift
      ;;
    --llama-context)
      if (($# < 2)); then
        echo "llama-codex: $1 requires a context window value" >&2
        exit 2
      fi
      context_window="$2"
      shift 2
      ;;
    --llama-context=*)
      context_window="${1#--llama-context=}"
      shift
      ;;
    --llama-lean)
      tool_profile="lean"
      apply_tool_profile
      shift
      ;;
    --llama-tiny)
      tool_profile="tiny"
      apply_tool_profile
      shift
      ;;
    --llama-tools)
      if (($# < 2)); then
        echo "llama-codex: $1 requires a profile value" >&2
        exit 2
      fi
      tool_profile="$2"
      apply_tool_profile
      shift 2
      ;;
    --llama-tools=*)
      tool_profile="${1#--llama-tools=}"
      apply_tool_profile
      shift
      ;;
    --llama-status)
      mkdir -p "${cache_dir}"
      echo "model=${model}"
      echo "context_window=${context_window}"
      echo "max_output_tokens=${max_output_tokens}"
      echo "ollama_url=${ollama_url}"
      echo "proxy_url=${proxy_url}"
      echo "ollama_num_parallel=${ollama_num_parallel}"
      echo "ollama_max_loaded_models=${ollama_max_loaded_models}"
      echo "tool_profile=${tool_profile}"
      echo "deny_tool_pattern=${deny_tool_pattern}"
      echo "reject_shell_writes=${reject_shell_writes}"
      echo "verify_command=${verify_command}"
      echo "verify_retries=${verify_retries}"
      echo "retry_context_bytes=${retry_context_bytes}"
      echo "base_instructions_source=${base_instructions_source}"
      echo "env_file=${env_file}"
      echo "model_catalog=${model_catalog}"
      exit 0
      ;;
    --llama-restart)
      restart_proxy=true
      shift
      ;;
    --llama-stop)
      stop_proxy=true
      shift
      ;;
    -y|--yes)
      assume_yes=true
      shift
      ;;
    --llama-help)
      cat <<'EOF'
llama-codex wraps Codex with an Ollama compatibility proxy.

Usage:
  llama-codex --yolo
  llama-codex init
  llama-codex init --yes
  llama-codex doctor
  llama-codex [codex options]
  llama-codex -m MODEL [codex options]
  llama-codex exec "task"

Default:
  Runs the normal Codex CLI against your local Ollama model.

Llama wrapper options:
  --llama-model MODEL       Select the Ollama model without passing -m to Codex.
  --llama-context TOKENS    Set advertised model context window.
  --llama-tools PROFILE     Select tool profile: lean, standard, full, or tiny.
  --llama-lean              Use the lean profile, which hides bulky non-coding tools and write_stdin.
  --llama-tiny              Use the tiny tool profile for strict benchmarks.
  --llama-status            Print resolved wrapper configuration and exit.
  --llama-restart           Restart the compatibility proxy before launching Codex.
  --llama-stop              Stop the compatibility proxy and exit.
  --llama-help              Show this help and exit.
  -y, --yes                 Approve supported dependency installs during init.

Codex model options:
  -m, --model MODEL         Select model for both Codex and the proxy.

Environment:
  LLAMA_CODEX_ENV_FILE
  LLAMA_CODEX_MODEL
  LLAMA_CODEX_CONTEXT_WINDOW
  LLAMA_CODEX_OLLAMA_URL
  LLAMA_CODEX_PROXY_HOST
  LLAMA_CODEX_PROXY_PORT
  LLAMA_CODEX_OLLAMA_NUM_PARALLEL
  LLAMA_CODEX_OLLAMA_MAX_LOADED_MODELS
  LLAMA_CODEX_TOOL_PROFILE       Defaults to lean.
  LLAMA_CODEX_DENY_TOOL_PATTERN
  LLAMA_CODEX_BASE_INSTRUCTIONS  Overrides default local-agent steering.
  LLAMA_CODEX_LOG_DIR
  LLAMA_CODEX_CACHE_DIR
EOF
      exit 0
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

install_hint() {
  case "$1" in
    codex)
      echo "npm install -g @openai/codex"
      ;;
    ollama)
      echo "brew install ollama"
      ;;
    python3)
      echo "brew install python"
      ;;
    curl)
      echo "brew install curl"
      ;;
  esac
}

install_dep() {
  local cmd="$1"
  local install_cmd
  install_cmd="$(install_hint "${cmd}")"

  if command_exists "${cmd}"; then
    return 0
  fi

  echo "missing: ${cmd}"
  echo "install: ${install_cmd}"

  if [[ "${assume_yes}" != true ]]; then
    if [[ ! -t 0 ]]; then
      echo "llama-codex: non-interactive shell; rerun with 'llama-codex init --yes' or install manually" >&2
      return 1
    fi
    read -r -p "Install ${cmd}? [y/N] " answer
    case "${answer}" in
      y|Y|yes|YES)
        ;;
      *)
        echo "skip: ${cmd}"
        return 1
        ;;
    esac
  fi

  case "$cmd" in
    codex)
      if ! command_exists npm; then
        echo "llama-codex: npm is required to install codex" >&2
        return 1
      fi
      npm install -g @openai/codex
      ;;
    ollama|python3|curl)
      if ! command_exists brew; then
        echo "llama-codex: Homebrew is required to install ${cmd}" >&2
        return 1
      fi
      case "$cmd" in
        ollama) brew install ollama ;;
        python3) brew install python ;;
        curl) brew install curl ;;
      esac
      ;;
  esac
}

ensure_init_deps() {
  local failed=0
  for cmd in curl python3 ollama codex; do
    if ! install_dep "${cmd}"; then
      failed=1
    fi
  done
  if [[ "${failed}" -ne 0 ]]; then
    echo "llama-codex: install missing dependencies, then rerun: llama-codex init" >&2
    exit 1
  fi
}

require_cmd() {
  if ! command_exists "$1"; then
    echo "llama-codex: $1 is not installed or not on PATH" >&2
    echo "llama-codex: run first: llama-codex init" >&2
    exit 127
  fi
}

wait_for_url() {
  local url="$1"
  for _ in {1..80}; do
    if curl -fsS "${url}" >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.5
  done
  return 1
}

proxy_model() {
  curl -fsS "${proxy_url}/api/tags" 2>/dev/null \
    | python3 -c 'import json,sys; data=json.load(sys.stdin); print(data["models"][0].get("model") or data["models"][0].get("name") or "")' 2>/dev/null \
    || true
}

proxy_context_window() {
  curl -fsS "${proxy_url}/api/tags" 2>/dev/null \
    | python3 -c 'import json,sys; data=json.load(sys.stdin); print(data["models"][0].get("context_window") or "")' 2>/dev/null \
    || true
}

proxy_max_output_tokens() {
  curl -fsS "${proxy_url}/api/tags" 2>/dev/null \
    | python3 -c 'import json,sys; data=json.load(sys.stdin); print(data["models"][0].get("max_output_tokens") or "")' 2>/dev/null \
    || true
}

proxy_deny_tool_pattern() {
  curl -fsS "${proxy_url}/api/tags" 2>/dev/null \
    | python3 -c 'import json,sys; data=json.load(sys.stdin); print(data["models"][0].get("deny_tool_pattern") or "")' 2>/dev/null \
    || true
}

proxy_reject_shell_writes() {
  curl -fsS "${proxy_url}/api/tags" 2>/dev/null \
    | python3 -c 'import json,sys; data=json.load(sys.stdin); print("1" if data["models"][0].get("reject_shell_writes") else "0")' 2>/dev/null \
    || true
}

model_installed() {
  model_name_installed "${model}"
}

model_name_installed() {
  local name="$1"
  ollama list 2>/dev/null | awk 'NR > 1 {print $1}' | python3 -c 'import sys; name=sys.argv[1]; names={line.strip() for line in sys.stdin if line.strip()}; accepted={name}; accepted |= ({name + ":latest"} if ":" not in name else set()); raise SystemExit(0 if names & accepted else 1)' "$name"
}

create_qwen3_65k_alias() {
  if model_name_installed "${qwen3_65k_alias}"; then
    return 0
  fi

  if ! model_name_installed "${qwen3_65k_base_model}"; then
    echo "pull base model: ${qwen3_65k_base_model}"
    ollama pull "${qwen3_65k_base_model}"
  fi

  local modelfile
  local blob_path
  modelfile="${cache_dir}/qwen3-coder-30b-65k.Modelfile"
  blob_path="$(ollama show "${qwen3_65k_base_model}" --modelfile | awk '/^FROM / {print $2; exit}')"
  if [[ -z "${blob_path}" ]]; then
    echo "llama-codex: could not resolve base model blob for ${qwen3_65k_base_model}" >&2
    return 1
  fi

  mkdir -p "${cache_dir}"
  cat >"${modelfile}" <<EOF
FROM ${blob_path}
PARAMETER num_ctx 65536
PARAMETER min_p 0
PARAMETER repeat_penalty 1.05
PARAMETER top_k 20
PARAMETER top_p 0.8
PARAMETER temperature 0.7
PARAMETER stop <|im_start|>
PARAMETER stop <|im_end|>
EOF

  echo "create model alias: ${qwen3_65k_alias} (ctx 65536)"
  ollama create "${qwen3_65k_alias}" -f "${modelfile}"
}

ensure_model_available() {
  if model_installed; then
    return 0
  fi

  if [[ "${model}" == "${qwen3_65k_alias}" ]]; then
    create_qwen3_65k_alias
    return $?
  fi

  return 1
}

start_ollama() {
  if curl -fsS "${ollama_url}/api/version" >/dev/null 2>&1; then
    return 0
  fi
  OLLAMA_NUM_PARALLEL="${ollama_num_parallel}" \
    OLLAMA_MAX_LOADED_MODELS="${ollama_max_loaded_models}" \
    nohup ollama serve >>"${log_dir}/llama-codex-ollama.log" 2>&1 &
  wait_for_url "${ollama_url}/api/version"
}

warn_large_context() {
  if [[ "${context_window}" =~ ^[0-9]+$ ]] && ((context_window > 16384)); then
    echo "llama-codex: warning: context ${context_window} can put heavy memory pressure on local models" >&2
    echo "llama-codex: use --llama-context 8192 if the system becomes unstable" >&2
  fi
}

kill_proxy_on_port() {
  if [[ -f "${pid_file}" ]]; then
    local pid
    pid="$(cat "${pid_file}" 2>/dev/null || true)"
    if [[ -n "${pid}" ]] && kill -0 "${pid}" >/dev/null 2>&1; then
      kill "${pid}" >/dev/null 2>&1 || true
      sleep 0.3
    fi
    rm -f "${pid_file}"
  fi

  if command -v lsof >/dev/null 2>&1; then
    local pids
    pids="$(lsof -tiTCP:"${proxy_port}" -sTCP:LISTEN 2>/dev/null || true)"
    if [[ -n "${pids}" ]]; then
      kill ${pids} >/dev/null 2>&1 || true
      sleep 0.3
    fi
  fi
}

write_model_catalog() {
  mkdir -p "${cache_dir}"
  python3 - "$model" "$context_window" "$model_catalog" "$base_instructions" <<'PY'
import json
import sys

model, context_window, path, base_instructions = sys.argv[1], int(sys.argv[2]), sys.argv[3], sys.argv[4]
data = {
    "models": [
        {
            "base_instructions": base_instructions,
            "context_window": context_window,
            "default_verbosity": "low",
            "display_name": model,
            "experimental_supported_tools": [],
            "input_modalities": ["text"],
            "priority": 0,
            "shell_type": "default",
            "slug": model,
            "support_verbosity": True,
            "supported_in_api": True,
            "supported_reasoning_levels": [],
            "supports_parallel_tool_calls": False,
            "supports_reasoning_summaries": False,
            "truncation_policy": {"limit": 10000, "mode": "bytes"},
            "visibility": "list",
        }
    ]
}
with open(path, "w", encoding="utf-8") as handle:
    json.dump(data, handle, indent=2)
    handle.write("\n")
PY
}

ensure_proxy() {
  local running_model
  local running_context_window
  local running_max_output_tokens
  local running_deny_tool_pattern
  local running_reject_shell_writes

  running_model="$(proxy_model)"
  running_context_window="$(proxy_context_window)"
  running_max_output_tokens="$(proxy_max_output_tokens)"
  running_deny_tool_pattern="$(proxy_deny_tool_pattern)"
  running_reject_shell_writes="$(proxy_reject_shell_writes)"
  if [[ "${restart_proxy}" == true ]] || \
    [[ -n "${running_model}" && "${running_model}" != "${model}" ]] || \
    [[ -n "${running_context_window}" && "${running_context_window}" != "${context_window}" ]] || \
    [[ -n "${running_max_output_tokens}" && "${running_max_output_tokens}" != "${max_output_tokens}" ]] || \
    [[ "${running_deny_tool_pattern}" != "${deny_tool_pattern}" ]] || \
    [[ -n "${running_reject_shell_writes}" && "${running_reject_shell_writes}" != "$(case "${reject_shell_writes}" in 1|true|TRUE|yes|YES|on|ON) echo 1 ;; *) echo 0 ;; esac)" ]]; then
    kill_proxy_on_port
  fi

  if ! curl -fsS "${proxy_url}/api/tags" >/dev/null 2>&1; then
    local proxy_guard_args=()
    case "${reject_shell_writes}" in
      1|true|TRUE|yes|YES|on|ON)
        proxy_guard_args+=(--reject-shell-writes)
        ;;
    esac
    nohup "${proxy_script}" \
      --host "${proxy_host}" \
      --port "${proxy_port}" \
      --backend "${ollama_url}" \
      --model "${model}" \
      --context-window "${context_window}" \
      --max-output-tokens "${max_output_tokens}" \
      --deny-tool-pattern "${deny_tool_pattern}" \
      "${proxy_guard_args[@]}" \
      >>"${log_dir}/llama-codex-proxy.log" 2>&1 &
    echo "$!" >"${pid_file}"

    if ! wait_for_url "${proxy_url}/api/tags"; then
      echo "llama-codex: could not start compatibility proxy at ${proxy_url}" >&2
      exit 1
    fi
  fi
}

doctor() {
  local failed=0
  echo "llama-codex doctor"
  echo

  for cmd in curl python3 ollama codex; do
    if command_exists "${cmd}"; then
      echo "ok   ${cmd}: $(command -v "${cmd}")"
    else
      echo "fail ${cmd}: missing from PATH"
      failed=1
    fi
  done

  if command_exists codex; then
    echo "ok   codex version: $(codex --version 2>/dev/null || echo unknown)"
  fi

  if command_exists ollama && curl -fsS "${ollama_url}/api/version" >/dev/null 2>&1; then
    echo "ok   ollama server: ${ollama_url}"
  else
    echo "fail ollama server: not reachable at ${ollama_url}"
    failed=1
  fi

  if command_exists ollama && ensure_model_available; then
    echo "ok   model installed: ${model}"
  else
    echo "fail model installed: ${model}"
    echo "     run: llama-codex init"
    failed=1
  fi

  if [[ -f "${model_catalog}" ]]; then
    echo "ok   model catalog: ${model_catalog}"
  else
    echo "fail model catalog: missing at ${model_catalog}"
    echo "     run: llama-codex init"
    failed=1
  fi

  local running_model
  local running_context_window
  running_model="$(proxy_model)"
  running_context_window="$(proxy_context_window)"
  if [[ "${running_model}" == "${model}" && "${running_context_window}" == "${context_window}" ]]; then
    echo "ok   proxy: ${proxy_url} (${running_model}, ctx ${running_context_window})"
  else
    echo "fail proxy: not ready for ${model} ctx ${context_window}"
    echo "     run: llama-codex init"
    failed=1
  fi

  return "${failed}"
}

run_codex_once() {
  codex \
    -c "model=\"${model}\"" \
    -c 'model_provider="ollama-launch"' \
    -c "model_catalog_json=\"${model_catalog}\"" \
    -c 'model_providers.ollama-launch.name="Ollama"' \
    -c "model_providers.ollama-launch.base_url=\"${proxy_url}/v1/\"" \
    -c 'model_providers.ollama-launch.wire_api="responses"' \
    "${args[@]}"
}

append_retry_instruction() {
  local instruction="$1"
  if ((${#args[@]})); then
    local last_index=$((${#args[@]} - 1))
    args[$last_index]+=$'\n\n'"${instruction}"
  else
    args+=("${instruction}")
  fi
}

replace_last_instruction() {
  local instruction="$1"
  if ((${#args[@]})); then
    local last_index=$((${#args[@]} - 1))
    args[$last_index]="${instruction}"
  else
    args+=("${instruction}")
  fi
}

snapshot_workspace() {
  local output="$1"
  python3 - "$PWD" "$output" <<'PY'
import hashlib
import os
import sys

root, output = sys.argv[1], sys.argv[2]
skip_dirs = {
    ".git",
    ".hg",
    ".svn",
    ".next",
    ".nuxt",
    ".pytest_cache",
    ".ruff_cache",
    ".tox",
    ".venv",
    "__pycache__",
    "coverage",
    "dist",
    "build",
    "node_modules",
    "target",
}
rows = []
for current, dirs, files in os.walk(root):
    dirs[:] = [name for name in dirs if name not in skip_dirs]
    for name in files:
        path = os.path.join(current, name)
        rel = os.path.relpath(path, root)
        try:
            stat = os.stat(path)
        except OSError:
            continue
        digest = hashlib.sha256()
        try:
            with open(path, "rb") as handle:
                for chunk in iter(lambda: handle.read(1024 * 1024), b""):
                    digest.update(chunk)
        except OSError:
            digest.update(f"{stat.st_mtime_ns}:{stat.st_size}".encode())
        rows.append((rel, stat.st_size, digest.hexdigest()))
with open(output, "w", encoding="utf-8") as handle:
    for rel, size, digest in sorted(rows):
        handle.write(f"{digest} {size} {rel}\n")
PY
}

retry_context_snapshot() {
  python3 - "$PWD" "$retry_context_bytes" <<'PY'
import os
import sys

root = sys.argv[1]
try:
    budget = max(0, int(sys.argv[2]))
except ValueError:
    budget = 0

if budget <= 0:
    raise SystemExit(0)

skip_dirs = {
    ".git",
    ".hg",
    ".svn",
    ".next",
    ".nuxt",
    ".pytest_cache",
    ".ruff_cache",
    ".tox",
    ".venv",
    "__pycache__",
    "coverage",
    "dist",
    "build",
    "node_modules",
    "target",
}
content_exts = {
    ".c",
    ".cc",
    ".cpp",
    ".css",
    ".go",
    ".h",
    ".hpp",
    ".html",
    ".java",
    ".js",
    ".json",
    ".jsx",
    ".md",
    ".py",
    ".rs",
    ".sh",
    ".toml",
    ".ts",
    ".tsx",
    ".yaml",
    ".yml",
}
content_names = {"README", "README.md", "Makefile", "package.json", "pyproject.toml"}
paths = []
for current, dirs, files in os.walk(root):
    dirs[:] = [name for name in dirs if name not in skip_dirs and not name.startswith(".")]
    for name in files:
        if name.startswith("."):
            continue
        path = os.path.join(current, name)
        rel = os.path.relpath(path, root)
        try:
            size = os.path.getsize(path)
        except OSError:
            continue
        paths.append((rel, size))

paths.sort()
lines = ["Workspace context snapshot:", "Files:"]
for rel, size in paths[:200]:
    lines.append(f"- {rel} ({size} bytes)")
remaining = budget - len("\n".join(lines).encode("utf-8")) - 2

for rel, size in paths:
    if remaining <= 0:
        break
    name = os.path.basename(rel)
    ext = os.path.splitext(name)[1]
    if ext not in content_exts and name not in content_names:
        continue
    if size > 12000:
        continue
    path = os.path.join(root, rel)
    try:
        with open(path, "r", encoding="utf-8") as handle:
            content = handle.read()
    except (OSError, UnicodeDecodeError):
        continue
    block = f"\n--- {rel} ---\n{content}"
    encoded = block.encode("utf-8")
    if len(encoded) > remaining:
        continue
    lines.append(block)
    remaining -= len(encoded)

print("\n".join(lines))
PY
}

run_with_optional_verification() {
  if [[ -z "${verify_command}" ]]; then
    exec codex \
      -c "model=\"${model}\"" \
      -c 'model_provider="ollama-launch"' \
      -c "model_catalog_json=\"${model_catalog}\"" \
      -c 'model_providers.ollama-launch.name="Ollama"' \
      -c "model_providers.ollama-launch.base_url=\"${proxy_url}/v1/\"" \
      -c 'model_providers.ollama-launch.wire_api="responses"' \
      "${args[@]}"
  fi

  local attempt=0
  local base_args=("${args[@]}")
  local verify_output
  local clean_verify_output
  local before_snapshot
  local after_snapshot
  local no_workspace_changes=false
  verify_output="$(mktemp)"
  clean_verify_output="$(mktemp)"
  before_snapshot="$(mktemp)"
  after_snapshot="$(mktemp)"
  while :; do
    snapshot_workspace "${before_snapshot}"
    set +e
    run_codex_once
    local codex_rc=$?
    snapshot_workspace "${after_snapshot}"
    bash -lc "${verify_command}" >"${verify_output}" 2>&1
    local verify_rc=$?
    set -e
    if cmp -s "${before_snapshot}" "${after_snapshot}"; then
      no_workspace_changes=true
    else
      no_workspace_changes=false
    fi
    sed -r 's/\x1B\[[0-9;]*[mK]//g' "${verify_output}" >"${clean_verify_output}"

    if [[ "${verify_rc}" -eq 0 ]]; then
      rm -f "${verify_output}" "${clean_verify_output}" "${before_snapshot}" "${after_snapshot}"
      exit 0
    fi

    if ((attempt >= verify_retries)); then
      echo "llama-codex: verification failed after $((attempt + 1)) attempt(s): ${verify_command}" >&2
      if [[ "${no_workspace_changes}" == true ]]; then
        echo "llama-codex: last attempt made no workspace file changes before verification" >&2
      fi
      sed -n '1,120p' "${clean_verify_output}" >&2
      rm -f "${verify_output}" "${clean_verify_output}" "${before_snapshot}" "${after_snapshot}"
      exit "${verify_rc}"
    fi

    attempt=$((attempt + 1))
    echo "llama-codex: verification failed; retrying attempt $((attempt + 1))/$((verify_retries + 1)): ${verify_command}" >&2
    args=("${base_args[@]}")
    retry_instruction="$(cat <<EOF
The previous attempt exited before satisfying verification.

Verification command:
${verify_command}

Verification output:
$(sed -n '1,50p' "${clean_verify_output}")

$(retry_context_snapshot)

$(if [[ "${no_workspace_changes}" == true ]]; then cat <<'NOCHANGE'
Premature stop detected: the previous attempt made no workspace file changes before verification.
The current workspace context is included above. Do not re-read files.
Do not explain the fix first.
Your first command in the next turn must be an apply_patch heredoc that changes an implementation file.
NOCHANGE
fi)

Continue from the current files. Do not restart from scratch.
Do not answer in prose or say what you will do next.
Your next assistant turn must call exec_command.
Do not put exec_command(...) text inside the shell command; the shell command must be plain shell such as apply_patch, npm test, sed -n, or cat.
Do not run rm, unlink, touch, sed -i, Python file writers, cat heredocs, tee, or shell redirects for source edits.
Use full-file replacement for stub, missing, or mostly unchanged implementation files. Do not use Update File hunks in this recovery turn.
Use exec_command to run apply_patch with this exact shape:
apply_patch <<'PATCH'
*** Begin Patch
*** Delete File: path/to/file
*** Add File: path/to/file
+full corrected file line 1
+full corrected file line 2
*** End Patch
PATCH
Do not use apply_patch --file or --patch flags.
Edit the implementation files, then run the verification command.
Continue until verification passes.
EOF
)"
    replace_last_instruction "${retry_instruction}"
  done
}

init() {
  ensure_init_deps

  mkdir -p "${log_dir}" "${cache_dir}"
  write_model_catalog

  echo "llama-codex init"
  echo "model: ${model}"
  echo "context: ${context_window}"
  echo "ollama parallelism: ${ollama_num_parallel}"
  echo "ollama max loaded models: ${ollama_max_loaded_models}"
  echo "tool profile: ${tool_profile}"
  echo "denied tools: ${deny_tool_pattern}"
  echo
  warn_large_context

  if ! start_ollama; then
    echo "llama-codex: could not start Ollama at ${ollama_url}" >&2
    exit 1
  fi
  echo "ok   ollama server: ${ollama_url}"

  if ensure_model_available; then
    echo "ok   model already installed"
  else
    echo "pull model: ${model}"
    ollama pull "${model}"
  fi

  ensure_proxy
  echo "ok   proxy: ${proxy_url}"
  echo "ok   model catalog: ${model_catalog}"
  echo
  doctor
}

mkdir -p "${log_dir}" "${cache_dir}"
write_model_catalog
warn_large_context

if [[ "${action}" == "doctor" ]]; then
  doctor
  exit $?
fi

if [[ "${action}" == "init" ]]; then
  init
  exit $?
fi

if [[ "${stop_proxy}" == true ]]; then
  kill_proxy_on_port
  echo "llama-codex: stopped proxy on ${proxy_url}"
  exit 0
fi

require_cmd curl
require_cmd python3
require_cmd ollama
require_cmd codex

if ! start_ollama; then
  echo "llama-codex: could not start Ollama at ${ollama_url}" >&2
  exit 1
fi

if ! ensure_model_available; then
  echo "llama-codex: model is not installed: ${model}" >&2
  echo "llama-codex: run first: llama-codex init" >&2
  exit 1
fi

ensure_proxy

run_with_optional_verification
